{
  "name": "vortex-v2",
  "private": true,
  "version": "1.0.3",
  "description": "Vortex V2 - System updater & tuner suite for CachyOS",
  "author": {
    "name": "Doodcom",
    "email": "a.munro87@icloud.com"
  },
  "homepage": "https://github.com/Doodcom/vortex-v2",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:electron": "electron-builder",
    "rebuild:native": "bash scripts/rebuild-native.sh",
    "test:e2e": "node tests/run-all.js"
  },
  "build": {
    "appId": "com.doodcom.vortex-v2",
    "productName": "Vortex V2",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "extraResources": [
      {
        "from": "build/icons/128x128.png",
        "to": "icon.png"
      }
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "pacman",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons",
      "category": "Utility",
      "executableArgs": [
        "--ozone-platform-hint=auto",
        "--enable-features=VaapiVideoDecodeLinuxGL,UseOzonePlatform,WaylandWindowDecorations",
        "--use-gl=egl",
        "--enable-gpu-rasterization"
      ]
    },
    "pacman": {
      "packageName": "vortex-v2",
      "maintainer": "Doodcom <a.munro87@icloud.com>",
      "compression": "xz",
      "depends": [
        "nss",
        "libxtst",
        "libxss",
        "gtk3",
        "mesa",
        "alsa-lib"
      ]
    }
  },
  "dependencies": {
    "axios": "^1.15.2",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "systeminformation": "^5.31.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.19",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "playwright-core": "^1.61.1",
    "postcss": "^8.4.39",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
